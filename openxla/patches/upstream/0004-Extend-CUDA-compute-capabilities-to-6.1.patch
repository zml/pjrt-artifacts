From 5bcc6b2b90d2fd5d22421947516a8e7e00e030f0 Mon Sep 17 00:00:00 2001
From: Sebastian Fischer <sebf.fischer@gmail.com>
Date: Tue, 7 Apr 2026 12:58:19 +0200
Subject: [PATCH] Extend CUDA compute capabilities to 6.1

---
 .bazelrc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.bazelrc b/.bazelrc
index a693dff..d438973 100644
--- a/.bazelrc
+++ b/.bazelrc
@@ -96,7 +96,7 @@ build:cuda --build_tag_filters -no_oss
 build:cuda --test_tag_filters -no_oss
 # build:cuda --config cuda_nvcc
 build:cuda --repo_env=HERMETIC_PYTHON_VERSION=3.11
-build:cuda --repo_env HERMETIC_CUDA_COMPUTE_CAPABILITIES="7.5,8.0,8.6,8.7,8.9,9.0,10.0,10.3,12.0,12.1"
+build:cuda --repo_env HERMETIC_CUDA_COMPUTE_CAPABILITIES="6.1,7.0,7.5,8.0,8.6,8.7,8.9,9.0,10.0,10.3,12.0,12.1"
 build:cuda --repo_env=HERMETIC_CUDA_VERSION="13.1.1"
 build:cuda --repo_env=HERMETIC_CUDNN_VERSION="9.19.1"
 build:cuda --repo_env=HERMETIC_NVSHMEM_VERSION="3.5.21"
