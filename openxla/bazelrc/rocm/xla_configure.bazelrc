build --repo_env=HERMETIC_PYTHON_VERSION=3.11
build:rocm_ci_hermetic --repo_env="ROCM_VERSION=7.1.1"

build --copt -Wno-sign-compare
build --copt -Wno-gnu-offsetof-extensions

build --build_tag_filters -no_oss
build --test_tag_filters -no_oss

test  --build_tag_filters -no_oss
test  --test_tag_filters -no_oss

common:baseline_arm64 --copt=-march=armv8.1-a # LSE atomics, server baseline ~2018+
common:baseline_x86_64   --copt=-march=x86-64-v3 # AVX2/FMA/BMI1/BMI2, Haswell-class servers+
